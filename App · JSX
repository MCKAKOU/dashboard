                      {curTabKpis[0].icon} {curTabKpis[0].label} — évolution
                    </span>
                    <span style={{ fontSize: 11, color: T.accent }}>
                      6 {mode === "semaine" ? "semaines" : "mois"}
                    </span>
                  </div>
                  <div style={{ height: 230 }}>
                    <KpiChart
                      data={curTabData[curTabKpis[0].key] ?? Array(6).fill(0)}
                      labels={labels}
                    />
                  </div>
                </div>
              )}
            </>
          )}
        </main>
      </div>
    </div>
  );
}
