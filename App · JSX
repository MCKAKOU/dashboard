// ─── UTILS ───────────────────────────────────────────────────────────────────
function fmt(val, unit) {
  if (unit === "€") return `${(+val).toLocaleString("fr-FR")}€`;
  if (unit === "K") return `${(+val).toFixed(1)}K`;
  if (unit === "x") return `${(+val).toFixed(2)}x`;
  if (unit === "%") return `${(+val).toFixed(1)}%`;
  return `${Math.round(+val).toLocaleString("fr-FR")}`;
}

function trendPct(arr, idx) {
  if (idx === 0 || !arr[idx - 1]) return 0;
  return Math.round(((arr[idx] - arr[idx - 1]) / arr[idx - 1]) * 1000) / 10;
}

function parseCsv(csv) {
  try {
    const lines = csv.trim().split("\n");
    const headers = lines[0].split(",").map((h) => h.trim().toLowerCase().replace(/\s+/g, "_"));
    return lines.slice(1).map((line) => {
      const cols = line.split(",");
      const row = {};
      headers.forEach((h, i) => { row[h] = cols[i]?.trim() ?? ""; });
      return row;
    });
  } catch { return []; }
}

// ─── SCORE RING ──────────────────────────────────────────────────────────────
function ScoreRing({ score }) {
  const r = 18;
  const circ = 2 * Math.PI * r;
  const offset = circ - (score / 100) * circ;
  const color = score >= 70 ? T.accent : score >= 45 ? T.yellow : T.red;
  return (
    <svg width="48" height="48" viewBox="0 0 48 48">
      <circle cx="24" cy="24" r={r} fill="none" stroke={T.border} strokeWidth="3" />
      <circle cx="24" cy="24" r={r} fill="none" stroke={color} strokeWidth="3"
        strokeDasharray={circ} strokeDashoffset={offset} strokeLinecap="round"
        transform="rotate(-90 24 24)" style={{ transition: "stroke-dashoffset 1s ease" }} />
      <text x="24" y="28" textAnchor="middle" fill={color} fontSize="11" fontWeight="700">{score}</text>
    </svg>
  );
}

// ─── KPI CARD ────────────────────────────────────────────────────────────────
function KpiCard({ def, value, trendVal }) {
  const isPos = trendVal > 0;
  const isNeg = trendVal < 0;
  const trendColor = isPos ? T.accent : isNeg ? T.red : T.muted;
  return (
    <div style={{
      background: T.card, border: `1px solid ${T.border}`, borderRadius: 16,
      padding: "16px 18px", display: "flex", flexDirection: "column", gap: 6,
      position: "relative", overflow: "hidden",
    }}>
      <div style={{ position: "absolute", top: 12, right: 14, fontSize: 22, opacity: 0.12 }}>{def.icon}</div>
      <span style={{ fontSize: 11, color: T.muted, fontWeight: 600, letterSpacing: "0.05em", textTransform: "uppercase" }}>
        {def.label}
      </span>
      <span style={{ fontSize: 24, fontWeight: 800, color: T.text, letterSpacing: "-0.02em" }}>
        {fmt(value, def.unit)}
      </span>
      <div style={{ display: "flex", alignItems: "center", gap: 5 }}>
        <span style={{ fontSize: 11, color: trendColor, fontWeight: 700 }}>
          {isPos ? "▲" : isNeg ? "▼" : "—"} {Math.abs(trendVal)}%
        </span>
        <span style={{ fontSize: 10, color: T.muted }}>vs période préc.</span>
      </div>
    </div>
  );
}

// ─── CHART TOOLTIP ───────────────────────────────────────────────────────────
function ChartTooltip({ active, payload, label }) {
  if (!active || !payload?.length) return null;
  return (
    <div style={{ background: T.card2, border: `1px solid ${T.border}`, borderRadius: 10, padding: "8px 14px" }}>
      <div style={{ fontSize: 11, color: T.muted, marginBottom: 3 }}>{label}</div>
      <div style={{ fontSize: 15, fontWeight: 700, color: T.accent }}>
        {payload[0].value?.toLocaleString("fr-FR")}
      </div>
    </div>
  );
}

// ─── AREA CHART ──────────────────────────────────────────────────────────────
function KpiChart({ data, labels }) {
  const chartData = labels.map((l, i) => ({ name: l, value: data[i] ?? 0 }));
  return (
    <ResponsiveContainer width="100%" height="100%">
      <AreaChart data={chartData} margin={{ top: 4, right: 4, left: -28, bottom: 0 }}>
        <defs>
          <linearGradient id="grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stopColor={T.accent} stopOpacity={0.35} />
            <stop offset="100%" stopColor={T.accent} stopOpacity={0}    />
          </linearGradient>
        </defs>
        <CartesianGrid stroke={T.border} strokeDasharray="3 3" vertical={false} />
        <XAxis dataKey="name" tick={{ fill: T.muted, fontSize: 11 }} axisLine={false} tickLine={false} />
        <YAxis tick={{ fill: T.muted, fontSize: 11 }} axisLine={false} tickLine={false} />
        <Tooltip content={<ChartTooltip />} />
        <Area type="monotone" dataKey="value" stroke={T.accent} strokeWidth={2.5}
          fill="url(#grad)" dot={false}
          activeDot={{ r: 5, fill: T.accent, stroke: T.bg, strokeWidth: 2 }} />
      </AreaChart>
    </ResponsiveContainer>
  );
}

// ─── IA TAB ──────────────────────────────────────────────────────────────────
function IaTab({ allData, periodIdx, periodLabel }) {
  const [loading, setLoading] = useState(false);
  const [result,  setResult]  = useState("");
  const [error,   setError]   = useState("");

  const analyze = useCallback(async () => {
    setLoading(true); setResult(""); setError("");

    const summary = Object.entries(allData)
      .map(([tab, kpis]) => {
        const lines = Object.entries(kpis)
          .map(([k, arr]) => `  ${k}: ${arr[periodIdx] ?? "-"}`)
          .join("\n");
        return `[${tab.toUpperCase()}]\n${lines}`;
      })
      .join("\n\n");

    const prompt = `Tu es une assistante virtuelle spécialisée en e-commerce. Analyse ces KPIs de la boutique "${CLIENT.name}" pour la période "${periodLabel}" :\n\n${summary}\n\nDonne une analyse concise (6-8 points max) en français avec :\n- Les points forts 🟢\n- Les alertes à surveiller 🔴\n- 3 actions prioritaires concrètes 🎯\nSois direct, chiffré et actionnable.`;

    try {
      // Appel via la Vercel Function /api/claude (qui injecte la clé côté serveur)
      const res = await fetch("/api/claude", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{ role: "user", content: prompt }],
        }),
      });
      const data = await res.json();
      if (data.error) throw new Error(typeof data.error === "string" ? data.error : data.error.message);
      const text = (data.content ?? []).map((b) => b.text ?? "").join("\n");
      setResult(text);
    } catch (e) {
      setError(`Erreur : ${e.message}`);
    } finally {
      setLoading(false);
    }
  }, [allData, periodIdx, periodLabel]);

  return (
    <div style={{ maxWidth: 680 }}>
      <div style={{
        background: `linear-gradient(135deg, ${T.card}, #131d2e)`,
        border: `1px solid ${T.border}`, borderRadius: 20,
        padding: 28, marginBottom: 20, textAlign: "center",
      }}>
        <div style={{ fontSize: 44, marginBottom: 12 }}>✦</div>
        <div style={{ fontSize: 20, fontWeight: 800, color: T.text, marginBottom: 8 }}>
          Analyse IA FlowBoard
        </div>
        <div style={{ fontSize: 14, color: T.muted, lineHeight: 1.6, marginBottom: 24 }}>
          Claude analyse l'ensemble de tes KPIs pour{" "}
          <strong style={{ color: T.text }}>{periodLabel}</strong> et identifie
          tes forces, alertes et actions prioritaires.
        </div>
        <button onClick={analyze} disabled={loading} style={{
          background: loading ? T.muted : T.accent, color: "#07090F",
          border: "none", borderRadius: 12, padding: "14px 36px",
          fontSize: 14, fontWeight: 800, cursor: loading ? "not-allowed" : "pointer",
          width: "100%", maxWidth: 320, letterSpacing: "0.02em", transition: "opacity 0.2s",
        }}>
          {loading ? "⟳  Analyse en cours…" : "✦  Analyser mes KPIs"}
        </button>
      </div>

      {error && (
        <div style={{
          background: "#1a0a0d", border: `1px solid ${T.red}`,
          borderRadius: 12, padding: 16, color: T.red, fontSize: 13, marginBottom: 16,
        }}>
          {error}
        </div>
      )}

      {result && (
        <div style={{ background: T.card, border: `1px solid ${T.border}`, borderRadius: 16, padding: 24 }}>
          <div style={{
            fontSize: 11, color: T.accent, fontWeight: 700,
            letterSpacing: "0.1em", textTransform: "uppercase", marginBottom: 16,
          }}>
            ✦ Résultat — {periodLabel}
          </div>
          <div style={{ fontSize: 14, color: T.text, lineHeight: 1.8, whiteSpace: "pre-wrap" }}>
            {result}
          </div>
        </div>
      )}
    </div>
  );
}

