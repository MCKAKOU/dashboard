function gen(base, vol = 0.15) {
  return Array.from({ length: 6 }, (_, i) => {
    const t = 1 + i * 0.04;
    const n = 1 + (Math.random() - 0.5) * vol * 2;
    return Math.round(base * t * n * 10) / 10;
  });
}

